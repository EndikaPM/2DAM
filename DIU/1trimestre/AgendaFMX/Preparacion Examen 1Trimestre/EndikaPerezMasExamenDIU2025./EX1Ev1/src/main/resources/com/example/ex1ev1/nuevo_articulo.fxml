<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" stylesheets="@DarckMode.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.ex1ev1.Controller.NuevoArticuloController">
    <children>
        <Label layoutX="252.0" layoutY="14.0" text="Crear Nuevo Articulo" />
        <GridPane layoutX="64.0" layoutY="88.0" prefHeight="195.0" prefWidth="468.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="228.0" minWidth="10.0" prefWidth="214.0" />
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="263.0" minWidth="10.0" prefWidth="254.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            </rowConstraints>
            <children>
                <Label text="Numero de productos distonibles: " />
                <Label text="Nombre" GridPane.rowIndex="2" />
                <Label text="Descripcion" GridPane.rowIndex="3" />
                <Label text="Precio" GridPane.rowIndex="4" />
                <Label text="Stock" GridPane.rowIndex="5" />
                <Label fx:id="NumProducDispoAdd" text="Label" GridPane.columnIndex="1" />
                <TextField fx:id="textFielNombre" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                <TextField fx:id="textFielDescrip" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                <TextField fx:id="textFielPrecio" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                <TextField fx:id="textFielStock" GridPane.columnIndex="1" GridPane.rowIndex="5" />

            </children>
        </GridPane>
        <Button layoutX="277.0" layoutY="323.0" mnemonicParsing="false" onAction="#handleAceptar" text="Aceptar" />
        <Button layoutX="444.0" layoutY="323.0" mnemonicParsing="false" onAction="#handleCancelar" text="Cancelar" />
    </children>
   <styleClass>
      <String fx:value="background" />
      <String fx:value="label-header" />
      <String fx:value="label-bright" />
   </styleClass>
</AnchorPane>
