<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="botonCalculadoraFunciones">
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/orange</item>
        <item name="cornerRadius">15dp</item>
        <item name="android:padding">5dp</item>
        <item name="android:width">90dp</item>
        <item name="android:height">70dp</item>
    </style>
    <style name="botonCalculadoraFuncionesMaterial">
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/orange</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:width">90dp</item>
        <item name="android:height">70dp</item>
    </style>
    <style name="botonCalculadora">
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/grey</item>
        <item name="cornerRadius">15dp</item>
        <item name="android:padding">5dp</item>
        <item name="android:width">90dp</item>
        <item name="android:height">70dp</item>
    </style>
    <style name="fondo">
        <item name="android:background">@color/black</item>
    </style>
    <style name="botonResto">
        <item name="android:textColor">@color/black</item>
        <item name="backgroundTint">@color/whiteDarck</item>
        <item name="android:textSize">20dp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">15dp</item>
        <item name="android:padding">5dp</item>
        <item name="android:width">90dp</item>
        <item name="android:height">70dp</item>
    </style>
</resources>