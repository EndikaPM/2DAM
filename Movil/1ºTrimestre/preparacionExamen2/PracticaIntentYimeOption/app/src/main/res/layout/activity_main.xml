<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/textoPantalla"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Introduzca los datos \npara enviar un mensaje"
        android:textAlignment="center"
        android:textSize="25dp"
        android:textStyle="bold"
        android:layout_marginBottom="30dp"/>

    <LinearLayout
        android:id="@+id/usuario_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/pedir_user"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Destinatario:"
            android:layout_marginHorizontal="10dp"/>

        <EditText
            android:id="@+id/username"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:hint="Introduce el nombre del destinatario"
            android:inputType="text"
            android:imeOptions="actionNext"
            android:maxLength="120" />
    </LinearLayout>
    <LinearLayout
        android:id="@+id/usuario_m"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="@id/usuario_name">

        <TextView
            android:id="@+id/pedir_m"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10dp"
            android:text="Mensaje:" />

        <EditText
            android:id="@+id/message"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:hint="Introduzca su mensaje"
            android:inputType="text"
            android:imeOptions="actionDone"
            android:maxLength="240"
            android:layout_marginLeft="20dp" />
    </LinearLayout>
    <com.google.android.material.button.MaterialButton
        android:id="@+id/send"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enviar mensaje"
        android:layout_marginTop="30dp"
        style="@style/ButtonStyle"/>

</LinearLayout>