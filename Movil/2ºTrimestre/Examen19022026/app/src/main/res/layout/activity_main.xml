<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:background="@color/black">

    <!-- ImageView que se moverá según el acelerómetro (centrado inicialmente) -->
    <ImageView
        android:id="@+id/imagen"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/ic_launcher_foreground"
        android:layout_gravity="center"
        android:contentDescription="Elemento que sigue los movimientos del acelerómetro" />

    <!-- LinearLayout con los TextViews de los valores del acelerómetro en la parte superior -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="top"
        android:padding="16dp"
        android:background="#80000000">

        <TextView
            android:id="@+id/textViewAX"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="X: 0.00"
            android:textColor="@color/white"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/textViewAY"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Y: 0.00"
            android:textColor="@color/white"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/textViewAZ"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Z: 0.00"
            android:textColor="@color/white"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/textViewA"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="A: 0.00"
            android:textColor="@color/white"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/textViewAmax"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Max: 0.00"
            android:textColor="@color/white"
            android:textSize="18sp" />

    </LinearLayout>

</FrameLayout>
