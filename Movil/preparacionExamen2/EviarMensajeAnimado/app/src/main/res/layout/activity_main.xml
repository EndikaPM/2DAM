<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:orientation="vertical"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/enviar_mensaje"
        style="@style/texViewPrincipal"/>
    <LinearLayout
        android:id="@+id/usuario_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView
            android:id="@+id/pedir_user"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Destinatario:"
            android:layout_marginHorizontal="10dp"/>
        <EditText
            android:id="@+id/username"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:hint="Introduce el nombre del destinatario"
            android:inputType="text"
            android:imeOptions="actionNext"
            android:maxLength="120" />
    </LinearLayout>
    <LinearLayout
        android:id="@+id/usuario_m"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/pedir_m"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10dp"
            android:text="Mensaje:" />

        <EditText
            android:id="@+id/message"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:hint="Introduzca su mensaje"
            android:imeOptions="actionDone"
            android:inputType="text"
            android:maxLength="240"
            android:layout_marginLeft="20dp" />
    </LinearLayout>

    <Button
        android:id="@+id/send"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enviar mensaje"
        android:layout_marginTop="30dp"
        style="@style/ButtonStyle"/>
</LinearLayout>