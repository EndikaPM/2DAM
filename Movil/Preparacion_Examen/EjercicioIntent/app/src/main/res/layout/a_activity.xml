<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ActivityA">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/vistaTexto"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:textSize="30dp"
        android:text="Antes de cambiar"
        android:textAlignment="center"/>

    <EditText
        android:id="@+id/textoEnviar"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBaseline_toBaselineOf="@+id/button_send"
        app:layout_constraintRight_toLeftOf="@+id/button_send"
        android:layout_marginRight="120dp"/>
    <!--app:layout_constraintBaseline_toBaselineOf="@+id/button_send"-->

    <!--Button
        style="@style/buttonEnvio"
        android:text="send"
        android:id="@+id/button_send"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:drawableRight="@drawable/outline_arrow_right_alt_24"
        app:layout_constraintHorizontal_bias="0.94"/-->

    <com.google.android.material.button.MaterialButton
        android:text="send"
        android:id="@+id/button_send"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:drawableRight="@drawable/outline_arrow_right_alt_24"
        app:layout_constraintHorizontal_bias="0.94"
        style="@style/buttonEnvio"/>

    <ToggleButton
        android:textOn="boton encendido"
        android:textOff="boton apagado"
        android:id="@+id/buttonInterruptor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/textoEnviar"
        android:drawableRight="@drawable/outline_arrow_right_alt_24"
        app:layout_constraintHorizontal_bias="0.63"
        style="@style/buttonEnvio" />
</androidx.constraintlayout.widget.ConstraintLayout>