<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/blueGren">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp"
        android:layout_marginTop="50dp">


        <TextView
            android:id="@+id/titulo_libro"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Título del Libro"
            android:textSize="25sp"
            android:textStyle="bold"
            android:textColor="@color/white"/>

        <ImageView
            android:id="@+id/icono_favorito"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_heart_empty"
            android:layout_marginStart="12dp" />
    </LinearLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/imagen_libro"
            android:layout_width="120dp"
            android:layout_height="180dp"
            android:scaleType="centerCrop"
            android:background="#E0E0E0"
            android:contentDescription="Portada del libro" />


        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="0dp">

            <TextView
                android:id="@+id/texto_libro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="DescripciónDescripciónDescripciónDescripciónDescripciónDescripción  "
                android:textSize="17sp"
                android:textColor="@color/white"
                android:lineSpacingExtra="2dp"
                android:maxLines="6"
                android:ellipsize="end" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/ic_menu_recent_history"
                    android:contentDescription="Fecha"
                    app:tint="@color/white" />

                <TextView
                    android:id="@+id/fecha_libro"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="01/01/2024"
                    android:textSize="13sp"
                    android:textColor="@color/white"
                    android:layout_marginStart="6dp" />
            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp" />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="start">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dinos que te ha parecido \nvota por tu libro."
                    android:textColor="@color/white"
                    android:layout_gravity="center"/>
                <RatingBar
                    android:layout_gravity="start"
                    android:id="@+id/valoracion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:scaleX="0.5"
                    android:scaleY="0.5"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:numStars="5"
                    android:stepSize="0.5"
                    android:progressBackgroundTint="#F2F1EE"
                    android:progressTint="#FFD700"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="200dp"
        android:orientation="vertical"
        android:gravity="center">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/backDetalle"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            style="@style/boton_guardar_registro"
            app:icon="@drawable/outline_arrow_back_ios_new_24"
            android:text="Pulsa para ver la lista completa"/>
    </LinearLayout>
</LinearLayout>